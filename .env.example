# Contact form email delivery (Resend — https://resend.com)
# Copy this file to `.env.local` for local dev, and set the same vars in
# Vercel → Project → Settings → Environment Variables for production.

# Your Resend API key (Resend dashboard → API Keys). Starts with "re_".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=fynarctechworks@gmail.com

# The "from" address emails are sent as. MUST be on a domain you've verified
# in Resend (Resend → Domains). Until your own domain is verified you can use
# Resend's shared testing sender: onboarding@resend.dev
CONTACT_FROM_EMAIL=FYN ARC Techworks <noreply@fynarctechworks.com>
